# Emberfire auth + MySQL config. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets. Read by auth_server.js (dotenv) and docker-compose.

# Auth server listen port (the patched client hardcodes 127.0.0.1:80 — keep 80)
AUTH_PORT=80

# MySQL (game/account data)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=dreadmyst

# docker-compose container root password (match DB_PASSWORD)
MYSQL_ROOT_PASSWORD=change_me
