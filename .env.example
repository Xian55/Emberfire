# Emberfire — ONE place for your local setup. Copy this to `.env` (gitignored) and fill it in,
# then apply it with:  powershell scripts/setup.ps1
#   - setx EMBERFIRE_DEPS_DIR / EMBERFIRE_GAME_DIR  (build/run; new shell to take effect)
#   - (re)writes auth/.env from the DB_* / AUTH_* / MYSQL_* values

# --- Build / run: paths to your prebuilt deps + the game runtime ---
EMBERFIRE_DEPS_DIR=C:\path\to\deps            # must contain  x86\SFML-2.6.1  and  zip\zip.dll
EMBERFIRE_GAME_DIR=C:\path\to\game-runtime    # content\ maps\ scripts\ game.db  config.ini  autoexec.conf

# --- Auth + MySQL (auth/.env is generated from these) ---
AUTH_PORT=80
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=dreadmyst
MYSQL_ROOT_PASSWORD=change_me

# --- Capture proxy (optional; defaults shown) ---
PROXY_PORT=16500
SERVER_HOST=127.0.0.1
SERVER_PORT=16383
